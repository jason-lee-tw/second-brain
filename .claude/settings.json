{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(*.env)",
      "Edit(*/.env)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)"
    ],
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(pytest:*)",
      "Bash(uv:*)",
      "Bash(just:*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet[1m]",
  "effortLevel": "max",
  "enabledPlugins": {
    "ponytail@ponytail": true,
    "verifying-implementation@verifying-implementation": true
  }
}
